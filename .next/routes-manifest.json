{
  "version": 3,
  "pages404": true,
  "appType": "pages",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/",
        "destination": "/index.html",
        "regex": "^/(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/repo/[path]",
      "regex": "^/api/repo/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/repo/(?<nxtPpath>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/about/about-us",
      "regex": "^/about/about\\-us(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about/about\\-us(?:/)?$"
    },
    {
      "page": "/about/execs",
      "regex": "^/about/execs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about/execs(?:/)?$"
    },
    {
      "page": "/api/repo",
      "regex": "^/api/repo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/repo(?:/)?$"
    },
    {
      "page": "/events",
      "regex": "^/events(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events(?:/)?$"
    },
    {
      "page": "/events/2025PiDay",
      "regex": "^/events/2025PiDay(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events/2025PiDay(?:/)?$"
    },
    {
      "page": "/events/Colloquium2025Feb13",
      "regex": "^/events/Colloquium2025Feb13(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events/Colloquium2025Feb13(?:/)?$"
    },
    {
      "page": "/events/Colloquium2025Feb27",
      "regex": "^/events/Colloquium2025Feb27(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events/Colloquium2025Feb27(?:/)?$"
    },
    {
      "page": "/events/Colloquium2025Mar13",
      "regex": "^/events/Colloquium2025Mar13(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events/Colloquium2025Mar13(?:/)?$"
    },
    {
      "page": "/events/Colloquium2025Mar6",
      "regex": "^/events/Colloquium2025Mar6(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events/Colloquium2025Mar6(?:/)?$"
    },
    {
      "page": "/events/example",
      "regex": "^/events/example(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events/example(?:/)?$"
    },
    {
      "page": "/events/PutnamDay",
      "regex": "^/events/PutnamDay(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events/PutnamDay(?:/)?$"
    },
    {
      "page": "/events/template",
      "regex": "^/events/template(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events/template(?:/)?$"
    },
    {
      "page": "/FAQs",
      "regex": "^/FAQs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/FAQs(?:/)?$"
    },
    {
      "page": "/repo",
      "regex": "^/repo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/repo(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}